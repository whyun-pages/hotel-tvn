{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./dist/cjs",
    "rootDir": "./",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "*.ts",
    "clis/tvn.ts",
    "clis/sgen.ts",
    "scripts/schedule-check-data.ts"
  ],
  "exclude": ["node_modules", "vitest.config.ts"]
}